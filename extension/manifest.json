{
  "manifest_version": 3,
  "name": "PasallyGlance",
  "version": "1.0.0",
  "description": "Select or right-click anything on a page for an instant, context-aware AI answer. Privacy-first, bring your own key.",
  "permissions": ["storage", "contextMenus", "identity"],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://*.supabase.co/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "PasallyGlance",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "src/background.js" },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_idle",
      "js": [
        "src/content/guard.js",
        "src/content/classify.js",
        "src/content/ui.js",
        "src/content/dwell.js",
        "src/content/adapters/gmail.js",
        "src/content/main.js"
      ]
    }
  ]
}
